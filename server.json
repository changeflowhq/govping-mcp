{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.changeflowhq/govping",
  "description": "Free regulatory intelligence. Search 27,000+ changes across 2,000+ government sources.",
  "repository": {

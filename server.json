    "source": "github"
  },
  "version": "1.0.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "govping-mcp-server",
      "version": "1.0.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": []
    }
  ],
  "remoteEndpoints": [
    {
      "url": "https://changeflow.com/govping/mcp",
      "transport": {
        "type": "streamableHttp"
      }
    }
  ]
}
